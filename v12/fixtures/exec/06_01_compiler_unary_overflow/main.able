package exec_06_01_compiler_unary_overflow

## Semantics: unary negation raises OverflowError when exceeding integer range.

fn uncompiled() -> void {
  1 match {
    case 1 => 1,
    case _ => 0
  }
  return
}

fn boom() -> i8 {
  value := -127_i8 - 1_i8
  return -value
}

fn main() -> void {
  uncompiled()
  boom()
  return
}
