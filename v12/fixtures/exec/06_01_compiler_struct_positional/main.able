package exec_06_01_compiler_struct_positional

## Semantics: compiler handles positional struct literals and index member access.

struct Pair { i32, i32 }

fn main() -> void {
  pair := Pair { 3, 4 }
  print(`pair ${pair.0},${pair.1}`)

  pair.0 = pair.0 + 1
  pair.1 = pair.1 + 2
  print(`mut ${pair.0},${pair.1}`)
}
