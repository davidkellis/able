package exec_06_01_compiler_or_else_mixed

## Semantics: compiler or-else handles mixed result types through runtime.Value.

fn maybe_text(ok: bool) {
  if ok { "ok" } else { nil }
}

fn main() -> void {
  mixed_nil = maybe_text(false) or { err => 9 }
  mixed_ok = maybe_text(true) or { err => 9 }

  print(`mixed_nil ${mixed_nil}`)
  print(`mixed_ok ${mixed_ok}`)
}
