package exec_06_01_compiler_divmod_overflow

## Semantics: compiled integer division raises OverflowError when the result is out of range.

fn uncompiled() -> void {
  1 match {
    case 1 => 1,
    case _ => 0
  }
  return
}

fn boom() -> i8 {
  value := -127_i8 - 1_i8
  return value // -1_i8
}

fn main() -> void {
  uncompiled()
  boom()
  return
}
