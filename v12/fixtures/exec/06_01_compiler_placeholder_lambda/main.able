package exec_06_01_compiler_placeholder_lambda

## Semantics: compiler lowers placeholder lambdas (@/@n) into callable values.

fn add(a: i32, b: i32) -> i32 { a + b }

fn combine(a: i32, b: i32, c: i32) -> i32 { a * 100 + b * 10 + c }

fn main() -> void {
  add_10 := add(@, 10)
  print(`add ${add_10(5)}`)

  square := @ * @
  print(`square ${square(6)}`)

  mixed := combine(@2, @, @3)
  print(`mixed ${mixed(7, 8, 9)}`)
}
