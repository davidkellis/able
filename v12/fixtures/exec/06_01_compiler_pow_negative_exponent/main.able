package exec_06_01_compiler_pow_negative_exponent

## Semantics: integer exponentiation rejects negative exponents.

fn uncompiled() -> void {
  1 match {
    case 1 => 1,
    case _ => 0
  }
  return
}

fn boom() -> i8 {
  exp := 0_i8 - 1_i8
  return 2_i8 ^ exp
}

fn main() -> void {
  uncompiled()
  boom()
  return
}
