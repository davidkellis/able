package exec_06_01_compiler_compound_assignment_overflow

## Semantics: compiled compound assignment raises OverflowError.

fn uncompiled() -> void {
  1 match {
    case 1 => 1,
    case _ => 0
  }
  return
}

fn boom() -> i8 {
  value := 127_i8
  value += 1_i8
  return value
}

fn main() -> void {
  uncompiled()
  boom()
  return
}
