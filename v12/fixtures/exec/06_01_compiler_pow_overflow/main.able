package exec_06_01_compiler_pow_overflow

## Semantics: integer exponentiation raises OverflowError when the result overflows.

fn uncompiled() -> void {
  1 match {
    case 1 => 1,
    case _ => 0
  }
  return
}

fn boom() -> i8 { 2_i8 ^ 7_i8 }

fn main() -> void {
  uncompiled()
  boom()
  return
}
